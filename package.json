{
  "name": "will-d-wang",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "pagefind --site out --output-path out/_pagefind",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "eslint-fix": "eslint . --fix",
    "eslint-pre-commit": "eslint --fix",
    "mdlint-fix": "markdownlint-cli2 --fix '**/*.md' '!.trunk' '!node_modules'",
    "mdlint-pre-commit": "markdownlint-cli2 --fix",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "module",
    "url": "https://github.com/will-d-wang/will-d-wang.github.io"
  },
  "author": "Will D. Wang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/will-d-wang/will-d-wang.github.io/issues"
  },
  "homepage": "https://github.com/will-d-wang/will-d-wang.github.io#readme",
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": "pnpm run eslint-pre-commit",
    "*.{md,mdx}": "pnpm run mdlint-pre-commit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/postcss": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.553.0",
    "next": "^16.1.1",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "tw-animate-css": "^1.4.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.3.0",
    "markdownlint-cli2": "^0.11.0",
    "pagefind": "^1.4.0",
    "prettier": "3.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
